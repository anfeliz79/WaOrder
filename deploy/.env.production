# ═══════════════════════════════════════════════════════════════════════════════
# WaOrder — Archivo .env para PRODUCCIÓN
#
# INSTRUCCIONES:
#   1. Copia este archivo al servidor: scp deploy/.env.production root@TU_IP:/var/www/waorder/.env
#   2. Edita los valores marcados con ← CAMBIAR
#   3. Ejecuta: bash deploy/deploy.sh
#
# IMPORTANTE: Este archivo contiene contraseñas. NUNCA lo subas a Git.
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME=WaOrder
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.com

# ← CAMBIAR: Tu dominio real (con https://)
# Si no tienes dominio aún, usa: APP_URL=http://TU_IP_DEL_DROPLET

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_DO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Base de datos ─────────────────────────────────────────────────────────────
# ← CAMBIAR: Usa la contraseña que el setup-server.sh generó/pediste
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=waorder
DB_USERNAME=waorder
DB_PASSWORD=TU_PASSWORD_MYSQL_AQUI

# ── Sesiones y caché ─────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Redis (opcional — descomenta si instalas Redis para más velocidad) ────────
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── WhatsApp Business API ────────────────────────────────────────────────────
# ← CAMBIAR: Obtener de Meta Business (developers.facebook.com)
WHATSAPP_VERIFY_TOKEN=waorder-verify-token-2026
WHATSAPP_APP_SECRET=TU_APP_SECRET_DE_META
WHATSAPP_API_VERSION=v21.0

# El verify_token lo inventas tú (cualquier texto secreto).
# Lo usarás al configurar el webhook en Meta Business.
# El app_secret lo obtienes de tu app en developers.facebook.com → Settings → Basic → App Secret

# ── AI / NLP (opcional — mejora el chatbot) ──────────────────────────────────
# Obtén una key gratis en https://console.groq.com
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
